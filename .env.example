# Capi Career Simulator: environment variables
# Copy VITE_ variables to `.env` for local frontend development.
# Put server-side variables in `.dev.vars` for local Cloudflare Functions.
# DO NOT commit `.env` or `.dev.vars`.

# Frontend variables (placed in `.env` locally)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-side variables (placed in `.dev.vars` locally,
# or Cloudflare Pages dashboard in production)
# Supabase server variables
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Used only for getUser(token) validation
SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Used for admin data access
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Session secret for HMAC-signed cookies
SESSION_SECRET=YOUR-SESSION-SECRET-MIN-32-CHARS

# Admin bootstrap allowlist.
# Used only while public.admins is empty. After the first admin row exists,
# database membership is authoritative and these variables no longer grant access.
ALLOWED_EMAIL=admin@example.com,user@example.com
ALLOWED_DOMAIN=example.com
