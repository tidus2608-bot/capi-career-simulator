# Capi Career Simulator — environment variables
# Copy to `.env` (or `.env.local`) and fill in real values.
# DO NOT commit `.env`.

# Supabase project (used by the React frontend)
# Get these from https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# For Cloudflare Pages production:
# Set VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY in the Pages dashboard
# under "Environment variables" for both Production and Preview environments.
